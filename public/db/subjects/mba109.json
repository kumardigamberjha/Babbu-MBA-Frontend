        {
          "topic_id": "t1",
          "title": "Introduction to Strategy",
          "difficulty": "easy",
          "estimated_time": "15 min",
          "prerequisites": [],
          "learning_outcomes": [
            "Understand what strategy is",
            "Differentiate strategy vs tactics"
          ],
          "content": "## Introduction to Strategy\nStrategy refers to a long-term plan designed to achieve competitive advantage and organizational goals.\n\n### Key Concepts\n- Strategy vs Tactics\n- Long-term focus\n- Resource allocation\n\n### Levels of Strategy\n- Corporate\n- Business\n- Functional\n\n### Importance\nProvides direction and helps organizations compete effectively.\n\n### Example\nA company deciding to enter a new international market is making a strategic decision.",
          "examples": [
            "Expansion into global markets",
            "Launching a new product line"
          ],
          "common_mistakes": [
            "Confusing tactics with strategy",
            "Short-term thinking"
          ],
          "qna": [
            {
              "q": "What is strategy?",
              "a": "A long-term plan to achieve goals."
            },
            {
              "q": "Difference between strategy and tactics?",
              "a": "Strategy is long-term, tactics are short-term actions."
            },
            {
              "q": "Levels of strategy?",
              "a": "Corporate, business, functional."
            },
            { "q": "Why is strategy important?", "a": "Provides direction." },
            { "q": "Example?", "a": "Entering new markets." }
          ]
        },
        {
          "topic_id": "t2",
          "title": "Vision, Mission, and Objectives",
          "difficulty": "easy",
          "estimated_time": "15 min",
          "prerequisites": ["t1"],
          "learning_outcomes": [
            "Understand vision and mission",
            "Set strategic objectives"
          ],
          "content": "## Vision, Mission, and Objectives\nOrganizations define their purpose and goals through vision and mission statements.\n\n### Vision\nFuture aspiration\n\n### Mission\nCurrent purpose\n\n### Objectives\nSpecific measurable goals\n\n### Importance\nAligns organization direction.",
          "examples": [
            "Becoming global leader",
            "Improving customer satisfaction"
          ],
          "common_mistakes": ["Vague statements", "Unrealistic goals"],
          "qna": [
            { "q": "What is vision?", "a": "Future aspiration." },
            { "q": "What is mission?", "a": "Current purpose." },
            { "q": "What are objectives?", "a": "Specific goals." },
            { "q": "Why important?", "a": "Provides direction." },
            { "q": "Example?", "a": "Increase market share." }
          ]
        }
      ]
    },

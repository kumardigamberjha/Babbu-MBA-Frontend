        {
          "topic_id": "t1",
          "title": "Accounting Concepts and Assumptions",
          "difficulty": "easy",
          "estimated_time": "20 min",
          "prerequisites": [],
          "learning_outcomes": [
            "Understand fundamental accounting concepts",
            "Apply assumptions in real scenarios"
          ],
          "content": "## Accounting Concepts and Assumptions\nAccounting is based on standard principles that ensure consistency and reliability.\n\n### Core Concepts\n- **Business Entity**: Owner and business are separate\n- **Going Concern**: Business will continue operations\n- **Accrual**: Record when earned/incurred\n- **Consistency**: Same methods over time\n\n### Why It Matters\nWithout these, financial statements would be inconsistent and unreliable.\n\n### Real Insight\nIf a company suddenly changes depreciation methods without reason, it may be manipulating profits.",
          "examples": [
            "Recording salary expense even if unpaid",
            "Maintaining same accounting policy yearly"
          ],
          "common_mistakes": [
            "Confusing cash vs accrual accounting",
            "Ignoring consistency principle"
          ],
          "qna": [
            {
              "q": "What is accrual concept?",
              "a": "Transactions are recorded when they occur, not when cash is exchanged."
            },
            {
              "q": "Why is consistency important?",
              "a": "It allows comparison across periods."
            },
            {
              "q": "What is going concern assumption?",
              "a": "Business is expected to continue operating."
            },
            {
              "q": "What happens if concepts are ignored?",
              "a": "Financial data becomes unreliable."
            },
            {
              "q": "Give a real-world implication.",
              "a": "Changing accounting methods to inflate profits."
            }
          ]
        },
        {
          "topic_id": "t2",
          "title": "Accounting Standards (GAAP & IFRS)",
          "difficulty": "medium",
          "estimated_time": "20 min",
          "prerequisites": ["t1"],
          "learning_outcomes": [
            "Understand accounting frameworks",
            "Compare GAAP and IFRS"
          ],
          "content": "## Accounting Standards\nAccounting standards ensure uniformity in financial reporting.\n\n### Major Frameworks\n- **GAAP** (US)\n- **IFRS** (Global)\n\n### Differences\n- GAAP is rule-based\n- IFRS is principle-based\n\n### Importance\nHelps investors compare companies globally.",
          "examples": [
            "Multinational companies using IFRS",
            "US firms using GAAP"
          ],
          "common_mistakes": [
            "Assuming all countries follow same standards",
            "Ignoring disclosure requirements"
          ],
          "qna": [
            { "q": "What is GAAP?", "a": "US-based accounting standards." },
            {
              "q": "What is IFRS?",
              "a": "International accounting framework."
            },
            {
              "q": "Key difference?",
              "a": "GAAP is rule-based, IFRS is principle-based."
            },
            { "q": "Why standards needed?", "a": "Ensure comparability." },
            { "q": "Who benefits?", "a": "Investors and regulators." }
          ]
        }
      ]

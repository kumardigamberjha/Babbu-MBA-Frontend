          "common_mistakes": ["Wrong weights", "Ignoring tax impact"],
          "qna": [
            { "q": "What is WACC?", "a": "Weighted cost of capital." },
            { "q": "Components?", "a": "Equity and debt." },
            { "q": "Why important?", "a": "Discount rate." },
            { "q": "Example?", "a": "Project evaluation." },
            { "q": "Risk?", "a": "Wrong decision." }
          ]
        }
      ]

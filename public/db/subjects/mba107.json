            "Poor receivable management"
          ],
          "qna": [
            {
              "q": "What is working capital?",
              "a": "Current assets minus liabilities."
            },
            { "q": "Why important?", "a": "Liquidity." },
            { "q": "Components?", "a": "Cash, inventory." },
            { "q": "Example?", "a": "Stock management." },
            { "q": "Risk?", "a": "Cash shortage." }
          ]
        }
      ]

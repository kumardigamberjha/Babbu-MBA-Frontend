          "difficulty": "medium",
          "estimated_time": "20 min",
          "prerequisites": [],
          "learning_outcomes": [
            "Compare management theories",
            "Understand evolution"
          ],
          "content": "## Evolution of Management Thought\nManagement evolved from rigid classical theories to flexible modern approaches.\n\n### Classical\n- Focus on efficiency\n\n### Behavioral\n- Focus on human relations\n\n### Modern\n- Systems and contingency approach\n\n### Importance\nHelps managers adapt to changing environments.",
          "examples": ["Taylorism vs modern HR practices"],
          "common_mistakes": [
            "Ignoring human factors",
            "Over-relying on rigid rules"
          ],
          "qna": [
            { "q": "What is classical theory?", "a": "Focus on efficiency." },
            { "q": "Behavioral theory?", "a": "Focus on people." },
            { "q": "Modern theory?", "a": "Flexible approach." },
            { "q": "Why evolution?", "a": "Changing business needs." },
            { "q": "Example?", "a": "Human relations approach." }
          ]
        }
      ]

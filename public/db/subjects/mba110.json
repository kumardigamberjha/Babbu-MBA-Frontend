        {
          "topic_id": "t1",
          "title": "Introduction to Business Ethics",
          "difficulty": "easy",
          "estimated_time": "15 min",
          "prerequisites": [],
          "learning_outcomes": [
            "Understand meaning of ethics",
            "Identify importance in business"
          ],
          "content": "## Business Ethics\nBusiness ethics refers to moral principles that guide behavior in business activities.\n\n### Key Concepts\n- Right vs wrong\n- Fairness\n- Integrity\n\n### Importance\n- Builds trust\n- Enhances reputation\n- Prevents legal issues\n\n### Example\nA company refusing to engage in bribery despite losing contracts.",
          "examples": [
            "Transparent pricing policies",
            "Avoiding corruption practices"
          ],
          "common_mistakes": [
            "Treating ethics as optional",
            "Ignoring long-term impact"
          ],
          "qna": [
            {
              "q": "What is business ethics?",
              "a": "Moral principles guiding business behavior."
            },
            { "q": "Why important?", "a": "Builds trust and reputation." },
            {
              "q": "What is integrity?",
              "a": "Acting honestly and consistently."
            },
            { "q": "Example?", "a": "Refusing bribery." },
            {
              "q": "Risk of ignoring ethics?",
              "a": "Legal and reputational damage."
            }
          ]
        },
        {
          "topic_id": "t2",
          "title": "Ethical Theories",
          "difficulty": "medium",
          "estimated_time": "20 min",
          "prerequisites": ["t1"],
          "learning_outcomes": [
            "Understand key ethical theories",
            "Apply theories in decision-making"
          ],
          "content": "## Ethical Theories\nEthical theories provide frameworks for decision-making.\n\n### Types\n- Utilitarianism: Greatest good for greatest number\n- Deontology: Duty-based ethics\n- Virtue Ethics: Character-based approach\n\n### Importance\nHelps evaluate business decisions ethically.",
          "examples": [
            "Choosing profit vs social good",
            "Following rules vs outcomes"
          ],
          "common_mistakes": [
            "Over-reliance on one theory",
            "Ignoring context"
          ],
          "qna": [
            {
              "q": "What is utilitarianism?",
              "a": "Maximizing overall happiness."
            },
            { "q": "What is deontology?", "a": "Duty-based ethics." },
            { "q": "Virtue ethics?", "a": "Focus on character." },
            { "q": "Why important?", "a": "Guides decisions." },
            { "q": "Example?", "a": "Choosing ethical sourcing." }
          ]
        }
      ]
